    "/about": {
      "seo": {
        "title": "Christine Gymwear Co. - Hand-Stitched in Point Cook, Worn Around the Globe",
        "description": "Discover Christine Gymwear Co., where Australian craftsmanship meets sustainable activewear. Handmade in Point Cook since 2015, our zero-waste production ensures premium, eco-conscious apparel that empowers you to move with confidence."
      },
      "sectionOrder": ["hero", "blocks"],
      "sections": {
        "hero": {
          "type": "hero",
          "variant": "simple",
          "props": {
            "background": "primary",
            "animation": "fade",
            "width": "default",
            "headline": "Hand‑Stitched in Point Cook, Worn Around the Globe",
            "subheadline": "At Christine Gymwear Co., every stitch is a promise of Australian quality. From our small workshop in Point Cook to elite athletes and everyday movers, we blend local craftsmanship with sustainable fabrics to create performance‑first apparel that feels as good as it looks.",
            "ctaText": "Get Started",
            "imageName": "https://loremflickr.com/1600/900/hand,stitched"
          }
        },
        "blocks": {
          "type": "blocks",
          "variant": "wide",
          "props": {
            "background": "default",
            "animation": "slide-up",
            "width": "default",
            "blocks": [
              {
                "type": "heading",
                "text": "Our Story: From Workshop to Wardrobe",
                "level": "h2",
                "align": "left",
                "spacing": "md"
              },
              {
                "type": "text",
                "content": "Founded in 2015, Christine Gymwear began as a passion project in a modest Point Cook garage. Today, we operate a zero‑waste production line that sources organic cotton and recycled polyester from certified Australian suppliers. Our mission is simple: deliver premium, eco‑conscious activewear that empowers you to move farther, faster, and more confidently. Every piece is cut, sewn, and inspected right here, ensuring the highest standards of durability and fit.",
                "align": "left",
                "spacing": "md"
              }
            ]
          }
        }
      }
    },
